# 範例 — 真正的值不會放這個檔案，是用 wrangler secret put 設到 Cloudflare Worker 環境
# 這檔只是文件，告訴你部署時要設哪兩顆 secret + wrangler.toml [vars] 要填什麼

# Notion integration token，縮限到只能 insert 你的記帳 DB
# 設法：echo "你的 token" | npx wrangler@latest secret put NOTION_TOKEN_EXPENSE_KR
NOTION_TOKEN_EXPENSE_KR=ntn_your_notion_integration_token

# Shortcut URL 上的防撞 secret，自己取一串隨機字串
# 設法：echo "你的 secret" | npx wrangler@latest secret put SHORTCUT_SECRET
SHORTCUT_SECRET=your_random_secret_string

# Notion data_source_id（不算 secret，存在 wrangler.toml [vars] 下）
# 從 GET /v1/databases/{db_id} 的 data_sources[0].id 取
NOTION_DATA_SOURCE_ID=your_notion_data_source_id
